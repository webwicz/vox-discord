# Discord Bot
DISCORD_TOKEN=your-bot-token-here
DISCORD_GUILD_ID=your-guild-id
DISCORD_CHANNEL_ID=your-voice-channel-id

# OpenAI Realtime API (Azure Foundry or direct OpenAI)
OPENAI_REALTIME_ENDPOINT=wss://your-resource.cognitiveservices.azure.com/openai/realtime
OPENAI_REALTIME_API_KEY=your-api-key
OPENAI_REALTIME_MODEL=gpt-realtime-mini

# Voice personality
VOICE_SYSTEM_PROMPT=You are a helpful voice assistant. Keep responses concise for voice.

# Workspace path (optional — defaults to current working directory)
# Recommended: ~/.openclaw/workspace for access to agent infrastructure
# VOX_WORKSPACE=$HOME/.openclaw/workspace

# Rezi Resume API (optional — required to enable resume management)
# Get token from: https://app.rezi.ai → Settings → Integrations
# REZI_API_TOKEN=your-rezi-pro-api-token-here
# REZI_PORT=3006

# VAD tuning (optional)
# VOX_VAD_TYPE=semantic_vad        # server_vad | semantic_vad | off
# VOX_EAGERNESS=medium             # low | medium | high (semantic_vad only)
# VOX_THRESHOLD=0.6                # 0.0-1.0 (server_vad only)
# VOX_SILENCE_DURATION=500         # ms (server_vad only)
# VOX_PREFIX_PADDING=300           # ms (server_vad only)
# VOX_VOICE=alloy                  # alloy | echo | shimmer | ash | ballad | coral | sage | verse
# VOX_TEMPERATURE=0.8              # 0.0-1.0
# VOX_CREATE_RESPONSE=true         # auto-respond after VAD detects end of speech
